<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<contentHaul xmlns:a="http://www.appian.com/ae/types/2009">
    <versionUuid>_a-0000ef65-c86c-8000-9c66-011c48011c48_1354361</versionUuid>
    <rule>
        <name>LM_ValidateLeaveBalance</name>
        <uuid>0afd1c48-ac5d-419a-a8fe-501ee16ba998</uuid>
        <description>Determines if an employee has sufficient leave balance for a requested leave duration based on leave type configuration.</description>
        <parentUuid>6e1f948d-128b-4dfc-a9cf-8db86b90bd40</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>a!localVariables(
  local!currentBalance: a!defaultValue(ri!currentBalance, 0),
  local!requestedDays: a!defaultValue(ri!requestedDays, 0),
  local!allowsNegative: a!defaultValue(ri!allowsNegativeBalance, false()),
  
  local!validationResult: if(
    local!allowsNegative,
    "Pass",
    if(
      local!currentBalance &gt;= local!requestedDays,
      "Pass",
      "Fail - Insufficient balance"
    )
  ),
  
  local!validationResult
)
</definition>
        <namedTypedValue>
            <name>currentBalance</name>
            <description>Employee's available days for the requested leave type</description>
            <type>
                <name>int</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <namedTypedValue>
            <name>requestedDays</name>
            <description>Calculated working days for the leave request</description>
            <type>
                <name>int</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <namedTypedValue>
            <name>allowsNegativeBalance</name>
            <description>Whether the leave type allows negative balance</description>
            <type>
                <name>boolean</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>

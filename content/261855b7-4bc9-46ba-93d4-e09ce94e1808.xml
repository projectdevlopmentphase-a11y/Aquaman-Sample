<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<contentHaul xmlns:a="http://www.appian.com/ae/types/2009">
    <versionUuid>_a-0000ef65-c86c-8000-9c66-011c48011c48_1354341</versionUuid>
    <rule>
        <name>LM_CalculateBalanceRestoration</name>
        <uuid>261855b7-4bc9-46ba-93d4-e09ce94e1808</uuid>
        <description>Computes the restored leave balance when a previously approved leave request is cancelled.</description>
        <parentUuid>6e1f948d-128b-4dfc-a9cf-8db86b90bd40</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>a!localVariables(
  local!currentBalance: a!defaultValue(ri!currentBalance, 0),
  local!cancelledDays: a!defaultValue(ri!cancelledDays, 0),
  
  local!restoredBalance: local!currentBalance + local!cancelledDays,
  
  local!restoredBalance
)
</definition>
        <namedTypedValue>
            <name>currentBalance</name>
            <description>Employee's current balance for the leave type</description>
            <type>
                <name>int</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <namedTypedValue>
            <name>cancelledDays</name>
            <description>Working days from the cancelled leave request</description>
            <type>
                <name>int</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>

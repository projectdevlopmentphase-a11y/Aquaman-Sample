<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<contentHaul xmlns:a="http://www.appian.com/ae/types/2009">
    <versionUuid>_a-0000ef65-c86c-8000-9c66-011c48011c48_1354346</versionUuid>
    <rule>
        <name>LM_CalculateLeaveUtilizationRate</name>
        <uuid>bfba662d-e4ee-4b7f-8a12-e2bf8e9d3f8f</uuid>
        <description>Computes an employee's leave utilization percentage for a specific leave type within the current year.</description>
        <parentUuid>6e1f948d-128b-4dfc-a9cf-8db86b90bd40</parentUuid>
        <visibility>
            <advertise>false</advertise>
            <hierarchy>true</hierarchy>
            <indexable>true</indexable>
            <quota>false</quota>
            <searchable>true</searchable>
            <system>false</system>
            <unlogged>false</unlogged>
        </visibility>
        <definition>a!localVariables(
  local!totalEntitlement: a!defaultValue(ri!totalEntitlement, 1),
  local!usedDays: a!defaultValue(ri!usedDays, 0),
  
  local!utilizationRate: if(
    local!totalEntitlement = 0,
    0,
    round((local!usedDays / local!totalEntitlement) * 100, 2)
  ),
  
  local!utilizationCategory: if(
    local!utilizationRate &gt;= 90,
    "High Usage",
    if(
      local!utilizationRate &gt;= 50,
      "Moderate Usage",
      "Low Usage"
    )
  ),
  
  a!map(
    "utilizationRate": local!utilizationRate,
    "utilizationCategory": local!utilizationCategory
  )
)
</definition>
        <namedTypedValue>
            <name>totalEntitlement</name>
            <description>Employee's annual entitlement for the leave type</description>
            <type>
                <name>int</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <namedTypedValue>
            <name>usedDays</name>
            <description>Sum of all approved leave days for the leave type in current year</description>
            <type>
                <name>int</name>
                <namespace>http://www.w3.org/2001/XMLSchema</namespace>
            </type>
        </namedTypedValue>
        <preferredEditor>legacy</preferredEditor>
        <offlineEnabled>false</offlineEnabled>
    </rule>
